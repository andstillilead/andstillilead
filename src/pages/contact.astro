---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — And Still, I Lead"
  description="Get in touch with Ciara LaVelle."
>
  <div class="container contact-container">
    <span class="tag-label">Contact</span>
    <h1 class="contact-title">Get in touch</h1>
    <div class="gold-bar"></div>
    <p class="contact-body">
      I'd love to hear from you — whether you want to share a reflection,
      ask a question, or just say hello.
    </p>
    <a href="mailto:hello@andstillilead.com" class="email-link">
      hello@andstillilead.com
    </a>
  </div>
</BaseLayout>

<style>
  .contact-container {
    padding: 64px 0 80px;
    max-width: 480px;
  }
  .tag-label { display: block; margin-bottom: 10px; }
  .contact-title {
    font-family: var(--font-serif);
    font-size: 34px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 18px;
  }
  .gold-bar {
    width: 36px;
    height: 2px;
    background: var(--gold);
    border-radius: 1px;
    margin-bottom: 28px;
  }
  .contact-body {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 24px;
  }
  .email-link {
    font-size: 15px;
    color: var(--gold);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }
  .email-link:hover { opacity: 0.7; }
</style>
