---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class:list={['author-row', { compact }]}>
  <div class="author-avatar" aria-hidden="true">CL</div>
  <div class="author-info">
    <span class="author-name">Ciara LaVelle</span>
    <span class="author-desc">
      {compact ? 'Writer · Leader · Still leading' : 'Writer · Leader · Still leading'}
    </span>
  </div>
</div>

<style>
  .author-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 24px;
    border-top: 0.5px solid var(--border);
    margin-top: 40px;
  }
  .author-row.compact {
    padding-top: 16px;
    margin-top: 28px;
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--nav-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 500;
    color: var(--gold);
    flex-shrink: 0;
    border: 0.5px solid var(--border);
  }
  .author-name {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }
  .author-desc {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
