---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class:list={['author-row', { compact }]}>
  <img class="author-avatar" src="/ciara.jpg" alt="Ciara LaVelle" />
  <div class="author-info">
    <span class="author-name">Ciara LaVelle</span>
    <span class="author-desc">
      {compact ? 'Writer · Leader · Still leading' : 'Writer · Leader · Still leading'}
    </span>
  </div>
</div>

<style>
  .author-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 24px;
    border-top: 0.5px solid var(--border);
    margin-top: 56px;
  }
  .author-row.compact {
    padding-top: 16px;
    margin-top: 28px;
  }
  .author-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 0.5px solid var(--border);
  }
  .author-name {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }
  .author-desc {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
